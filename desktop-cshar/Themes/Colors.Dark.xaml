<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#2A2A2A" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#252526" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#202225" />
    <SolidColorBrush x:Key="BorderBrushTheme" Color="#3A3A3A" />

    <SolidColorBrush x:Key="TextBrushTheme" Color="#F5F5F5" />
