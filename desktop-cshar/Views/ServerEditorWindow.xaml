<Window x:Class="desktop_cshar.ServerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Editor"
        Height="360"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Name:"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"/>
        <TextBox Grid.Row="0"
                 Grid.Column="1"
                 x:Name="NameTextBox"/>

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="Base URL:"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"/>
        <TextBox Grid.Row="2"
                 Grid.Column="1"
                 x:Name="BaseUrlTextBox"/>

        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Text="Description:"
                   VerticalAlignment="Top"
                   FontWeight="SemiBold"/>
        <TextBox Grid.Row="4"
                 Grid.Column="1"
                 x:Name="DescriptionTextBox"
                 Height="70"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"/>

        <TextBlock Grid.Row="6"
                   Grid.Column="0"
                   Text="Category:"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"/>
        <TextBox Grid.Row="6"
                 Grid.Column="1"
                 x:Name="CategoryTextBox"/>

        <CheckBox Grid.Row="8"
                  Grid.Column="1"
                  x:Name="IsEnabledCheckBox"
                  Content="Enabled"
                  IsChecked="True"/>

        <StackPanel Grid.Row="10"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="90"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>

            <Button Content="Save"
                    Width="90"
                    Height="32"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>